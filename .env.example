# --- Formulaire de contact (Resend) ---
# Clé API Resend. À créer sur https://resend.com (gratuit jusqu'à 3000 emails/mois).
# À définir dans Vercel : Project Settings > Environment Variables.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Adresse qui reçoit les demandes du formulaire.
CONTACT_TO_EMAIL="contact@aksmotors.com"

# Expéditeur. Tant que le domaine aksmotors.com n'est PAS vérifié dans Resend,
# laisser l'expéditeur de test ci-dessous. Une fois le domaine vérifié dans
# Resend (DNS), remplacer par : "AKS Motors <contact@aksmotors.com>".
CONTACT_FROM_EMAIL="AKS Motors <onboarding@resend.dev>"
